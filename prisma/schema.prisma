generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  meetups              Meetup[]
  votes                Vote[]
  meetupRegistrations  MeetupRegistration[]
  guestGamesAdded      MeetupGuestGame[]
}

model Game {
  id                      Int      @id // BGG object id
  name                    String
  year                    Int?
  description             String?
  image                   String?
  thumbnail               String?
  minPlayers              Int?
  maxPlayers              Int?
  playingTime             Int?
  minPlaytime             Int?
  maxPlaytime             Int?
  weight                  Float?
  bggRating               Float?
  rank                    Int?
  ageRange                String?
  languageDependence      String?
  isExpansion             Boolean  @default(false)
  expandsGameIds          Int[]    @default([])
  categories              String[]
  mechanics               String[]
  bestPlayerCounts        Int[]
  recommendedPlayerCounts Int[]
  enriched                Boolean  @default(false)
  listedInCollection      Boolean  @default(true)
  lentOut                 Boolean  @default(false)
  barcode                String?  @unique
  manuallyEditedFields    String[] @default([])
  updatedAt               DateTime @updatedAt

  votesAsWinner    Vote[]             @relation("VoteWinner")
  votesAsOpponent  Vote[]             @relation("VoteOpponent")
  meetupGuestGames    MeetupGuestGame[]
  meetupHostChoiceGames MeetupHostChoiceGame[]
  meetupsForcedAsGame Meetup[] @relation("MeetupForcedGame")
}

enum HostChoiceMode {
  NONE
  HIGHLIGHT
  RESTRICT
}

enum VoteMode {
  PICK
  DUEL
  EXPANSION_DUEL
}

model Meetup {
  id                         String    @id @default(cuid())
  title                      String
  scheduledAt                DateTime?
  location                   String?
  expectedPlayerCount        Int       @default(4)
  initialExpectedPlayerCount Int       @default(4)
  registrationPeakCount      Int       @default(1)
  createdById                String
  createdBy                  User      @relation(fields: [createdById], references: [id])
  createdAt                  DateTime  @default(now())
  duelFrozenAt               DateTime?
  duelFrozenData             Json?
  expansionDuelStartedAt     DateTime?
  expansionDuelFrozenData    Json?
  hostForcedGameId           Int?
  hostForcedGame             Game?          @relation("MeetupForcedGame", fields: [hostForcedGameId], references: [id], onDelete: SetNull)
  hostForcedAt               DateTime?
  hostChoiceMode             HostChoiceMode @default(NONE)

  votes                Vote[]
  registrations        MeetupRegistration[]
  guestGames           MeetupGuestGame[]
  hostChoiceGames      MeetupHostChoiceGame[]
  mandatoryExpansions  MeetupMandatoryExpansion[]
}

model MeetupMandatoryExpansion {
  id              String @id @default(cuid())
  meetupId        String
  meetup          Meetup @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  baseGameId      Int
  expansionGameId Int

  @@unique([meetupId, baseGameId, expansionGameId])
  @@index([meetupId, baseGameId])
}

model MeetupGuestGame {
  id        String   @id @default(cuid())
  meetupId  String
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  gameId    Int
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  addedById String
  addedBy   User     @relation(fields: [addedById], references: [id])
  createdAt DateTime @default(now())

  @@unique([meetupId, gameId])
  @@index([meetupId])
}

model MeetupHostChoiceGame {
  id        String   @id @default(cuid())
  meetupId  String
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  gameId    Int
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([meetupId, gameId])
  @@index([meetupId])
}

model MeetupRegistration {
  id        String   @id @default(cuid())
  meetupId  String
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([meetupId, userId])
  @@index([meetupId])
}

model Vote {
  id          String   @id @default(cuid())
  meetupId    String
  meetup      Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId           Int
  game             Game     @relation("VoteWinner", fields: [gameId], references: [id], onDelete: Cascade)
  opponentGameId   Int?
  opponentGame     Game?    @relation("VoteOpponent", fields: [opponentGameId], references: [id], onDelete: Cascade)
  playerCount      Int
  points      Int      @default(1)
  mode        VoteMode
  createdAt   DateTime @default(now())

  @@index([meetupId, playerCount])
  @@index([meetupId, gameId, playerCount])
}
