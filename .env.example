# Postgres connection string (Neon, Supabase, local docker, ...)
DATABASE_URL="postgresql://user:password@host:5432/bgbuddy?sslmode=require"

# Secret for signing the session cookie. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# BGG API token — optional. Only for live enrichment (npm run enrich / prefetch-bgg).
# Without token: use docs/browser-prefetch-bgg.md and data/bgg-enrichment.json instead.
# Register at https://boardgamegeek.com/applications
BGG_TOKEN=""

# GameUPC barcode lookup — optional. Demo/test API works without key on api.gameupc.com/test/.
# Docs: https://www.gameupc.com/api — contact gameupc@grettir.org for production key.
GAMEUPC_API_KEY=""
