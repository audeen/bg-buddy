# Postgres connection string (Neon, Supabase, local docker, ...)
DATABASE_URL="postgresql://user:password@host:5432/bgbuddy?sslmode=require"

# Secret for signing the session cookie. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# BGG API token (required for enrichment / cover & description fetching).
# The BGG XML API requires a token since 2025. Register an application at
# https://boardgamegeek.com/applications and generate a token.
# Leave empty to skip enrichment (the app still works with CSV data only).
BGG_TOKEN=""
